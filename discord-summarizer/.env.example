# ── Bot Discord (dùng cho Server B nếu muốn dùng bot thay webhook) ───────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── User Token (dùng cho DiscordChatExporter đọc Server A) ───────────────────
# Cách lấy: xem hướng dẫn bên dưới
DISCORD_USER_TOKEN=your_discord_user_token_here

# ── Gemini API (không bắt buộc nếu dùng Claude thủ công) ─────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server A: Guild ID + Category IDs (chuột phải → Copy ID, cần bật Developer Mode) ──
SERVER_A_GUILD_ID=your_server_a_guild_id
# Ngăn cách bằng dấu phẩy nếu có nhiều category
SOURCE_CATEGORY_IDS=category_id_1,category_id_2

# ── Webhook URL kênh Server B để nhận tóm tắt ────────────────────────────────
# Cách tạo: Server B → kênh muốn nhận → Edit Channel → Integrations → Webhooks
SERVER_B_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
